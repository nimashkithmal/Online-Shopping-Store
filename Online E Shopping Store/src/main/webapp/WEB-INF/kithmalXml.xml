<?xml version="1.0" encoding="UTF-8"?>
<web-app xmlns="http://xmlns.jcp.org/xml/ns/javaee"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="http://xmlns.jcp.org/xml/ns/javaee
         http://xmlns.jcp.org/xml/ns/javaee/web-app_3_1.xsd"
         version="3.1">


     <servlet>
     	<servlet-name>KithmalInsertServlet</servlet-name>
     	<servlet-class>onlineEShoppingStore.KithmalInsertServlet</servlet-class>
     </servlet>
     <servlet-mapping>
     	<servlet-name>KithmalInsertServlet</servlet-name>
     	<url-pattern>/KithmalInsertServlet</url-pattern>
     </servlet-mapping>
     
     <servlet>
     	<servlet-name>KithmalGetAllServlet</servlet-name>
     	<servlet-class>onlineEShoppingStore.KithmalGetAllServlet</servlet-class>
     </servlet>
     <servlet-mapping>
     	<servlet-name>KithmalGetAllServlet</servlet-name>
     	<url-pattern>/KithmalGetAllServlet</url-pattern>
     </servlet-mapping>
     
     <servlet>
     	<servlet-name>KithmalUpdateServlet</servlet-name>
     	<servlet-class>onlineEShoppingStore.KithmalUpdateServlet</servlet-class>
     </servlet>
     <servlet-mapping>
     	<servlet-name>KithmalUpdateServlet</servlet-name>
     	<url-pattern>/KithmalUpdateServlet</url-pattern>
     </servlet-mapping>

	<servlet>
     	<servlet-name>KithmalDeleteServlet</servlet-name>
     	<servlet-class>onlineEShoppingStore.KithmalDeleteServlet</servlet-class>
     </servlet>
     <servlet-mapping>
     	<servlet-name>KithmalDeleteServlet</servlet-name>
     	<url-pattern>/KithmalDeleteServlet</url-pattern>
     </servlet-mapping>

</web-app>